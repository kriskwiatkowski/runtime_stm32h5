{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 13,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "toolchainFile": "${sourceDir}/toolchains/gcc-armv8_m.main-unknown-none-eabi.cmake",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/${presetName}"
            }
        },
        {
            "name": "stm32h5",
            "inherits": "base",
            "displayName": "ARMv8-M Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "stm32h5-minsizerel",
            "inherits": "base",
            "displayName": "ARMv8-M MinSizeRel",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel"
            }
        },
        {
            "name": "stm32h5-reldebinfo",
            "inherits": "base",
            "displayName": "ARMv8-M RelWithDebInfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "base",
            "hidden": true,
            "targets": [
                "all",
                "install"
            ]
        },
        {
            "name": "stm32h5",
            "configurePreset": "stm32h5",
            "inherits": "base"
        },
        {
            "name": "stm32h5-minsizerel",
            "configurePreset": "stm32h5-minsizerel",
            "inherits": "base"
        },
        {
            "name": "stm32h5-reldebinfo",
            "configurePreset": "stm32h5-reldebinfo",
            "inherits": "base"
        }
    ],
    "packagePresets": [
        {
            "name": "stm32h5",
            "configurePreset": "stm32h5",
            "packageDirectory": "${sourceDir}/out/package/${presetName}"
        },
        {
            "name": "stm32h5-minsizerel",
            "configurePreset": "stm32h5-minsizerel",
            "packageDirectory": "${sourceDir}/out/package/${presetName}"
        },
        {
            "name": "stm32h5-reldebinfo",
            "configurePreset": "stm32h5-reldebinfo",
            "packageDirectory": "${sourceDir}/out/package/${presetName}"
        }
    ]
}